{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server.py",
            "env": {
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1"
            },
            "console": "integratedTerminal"
        }
    ]
}